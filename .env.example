# Example environment variables for EinvaBill
# Copy to .env and fill values on production server (DO NOT commit .env)

# Master unlimited license key (keep secret)
MASTER_KEY=EB-ULTIMATE-2026

# Salt used for license CRC
EINVABILL_SALT=EINVABILL_SECRET

# Optional: other environment variables
# DB_PATH=/var/www/einvabill/database.sqlite
# APP_DEBUG=0
